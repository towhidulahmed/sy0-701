generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Domain {
  id        Int        @id @default(autoincrement())
  key       String     @unique
  name      String
  weightPct Int
  topics    Topic[]
  questions Question[]
  results   DomainScore[]
}

model Topic {
  id             Int     @id @default(autoincrement())
  slug           String  @unique
  title          String
  studyPath      String
  content        String
  keyTerms       String
  examples       String
  tips           String
  domainId       Int
  domain         Domain  @relation(fields: [domainId], references: [id])
  questions      Question[]
  progress       StudyProgress?
  recommendedFor WrongAnswer[]
}

model Question {
  id          Int      @id @default(autoincrement())
  qid         String   @unique
  prompt      String
  type        String
  difficulty  String
  options     String
  answer      String
  explanation String
  scenario    String?
  domainId    Int
  domain      Domain   @relation(fields: [domainId], references: [id])
  topicId     Int
  topic       Topic    @relation(fields: [topicId], references: [id])
  wrongAnswers WrongAnswer[]
}

model TestResult {
  id             Int           @id @default(autoincrement())
  mockTestNumber Int
  startedAt      DateTime
  completedAt    DateTime
  score900       Int
  pass           Boolean
  elapsedSeconds Int
  answers        String
  createdAt      DateTime      @default(now())
  domainScores   DomainScore[]
  wrongAnswers   WrongAnswer[]
}

model DomainScore {
  id           Int        @id @default(autoincrement())
  domainId      Int
  domain        Domain     @relation(fields: [domainId], references: [id])
  testResultId  Int
  testResult    TestResult @relation(fields: [testResultId], references: [id])
  correct       Int
  total         Int
  pct           Float
}

model WrongAnswer {
  id               Int        @id @default(autoincrement())
  testResultId     Int
  testResult       TestResult @relation(fields: [testResultId], references: [id])
  questionId       Int
  question         Question   @relation(fields: [questionId], references: [id])
  selectedAnswer   String
  correctAnswer    String
  explanation      String
  recommendedTopic String
  topicId          Int
  topic            Topic      @relation(fields: [topicId], references: [id])
}

model StudyProgress {
  id        Int      @id @default(autoincrement())
  topicId   Int      @unique
  topic     Topic    @relation(fields: [topicId], references: [id])
  studied   Boolean  @default(false)
  updatedAt DateTime @updatedAt
}
